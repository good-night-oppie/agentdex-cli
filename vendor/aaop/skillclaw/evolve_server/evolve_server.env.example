# ===================================================================== #
#  Evolve Server runtime .env template                                  #
#  Runtime file location: evolve_server/.env                            #
#  Copy from repo root:                                                 #
#    cp evolve_server/evolve_server.env.example evolve_server/.env      #
# ===================================================================== #

# ----- Shared Object Storage ----- #
EVOLVE_ENGINE=workflow
EVOLVE_STORAGE_BACKEND=oss
EVOLVE_STORAGE_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
EVOLVE_STORAGE_BUCKET=my-skillclaw-bucket
EVOLVE_STORAGE_ACCESS_KEY_ID=your-storage-access-key-id
EVOLVE_STORAGE_SECRET_ACCESS_KEY=your-storage-secret-access-key
EVOLVE_GROUP_ID=default

# ----- LLM API ----- #
OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
EVOLVE_MODEL=kimi-k2.5
EVOLVE_LLM_MAX_TOKENS=4096
EVOLVE_LLM_TEMPERATURE=0.4

# Optional workflow publish gate: verify a candidate skill before upload.
EVOLVE_USE_SKILL_VERIFIER=0
EVOLVE_SKILL_VERIFIER_MIN_SCORE=0.75

# Optional publish mode:
# - direct: write accepted workflow outputs straight to skills/
# - validated: stage candidate skills and wait for opted-in clients to review them
EVOLVE_PUBLISH_MODE=direct
EVOLVE_VALIDATION_REQUIRED_RESULTS=1
EVOLVE_VALIDATION_REQUIRED_APPROVALS=1
EVOLVE_VALIDATION_MIN_MEAN_SCORE=0.75
EVOLVE_VALIDATION_MAX_REJECTIONS=1

# ----- Scheduling ----- #
EVOLVE_INTERVAL=600
EVOLVE_PORT=8787

# ----- Local persistence ----- #
EVOLVE_HISTORY_LOG=evolve_history.jsonl

# ----- Agent engine (optional) ----- #
AGENT_EVOLVE_OPENCLAW_BIN=openclaw
AGENT_EVOLVE_LLM_BASE_URL=https://api.openai.com/v1
AGENT_EVOLVE_MODEL=gpt-5.4
AGENT_EVOLVE_LLM_API_TYPE=openai-completions
