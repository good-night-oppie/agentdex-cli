# ============================================================================
# Agentic-Harness-Engineering 环境变量模板
# 用法: cp .env.example .env 并填入真实值。.env 已加入 .gitignore。
# ============================================================================

# ---- 主 LLM（必需）---------------------------------------------------------
# configs/base.yaml 的顶层 llm: 和 code_agent_patch 通过 ${LLM_*} 引用；
# evolve.py 会据此派生 LLM_API_KEY / LLM_BASE_URL / LLM_MODEL 注入给
# evolve_agent.yaml 的 ${env.LLM_*}。默认模型 nex-agi/deepseek-v3.1-nex-1。
LLM_API_KEY="your_primary_llm_api_key"
LLM_BASE_URL="https://api.example.com/v1"

# ---- ADB debugger 专用 LLM（configs/base.yaml agent_debugger.llm 引用）------
# 不设则 ADB 会用同一套 LLM_*，建议独立以使用 gpt-5.4 等推理模型。
ADB_LLM_API_KEY="your_adb_llm_api_key"
ADB_LLM_BASE_URL="https://api.example.com/v1"

# ---- 实验专用 LLM（configs/experiments/exp-003-simple-code-gpt54.yaml）-----
GPT54_LLM_API_KEY="your_gpt54_llm_api_key"
GPT54_LLM_BASE_URL="https://api.example.com/v1"

# ---- E2B 沙箱（必需）-------------------------------------------------------
E2B_API_KEY="your_e2b_api_key"
# 自建 e2b 集群时填，cloud 版可留空
E2B_API_URL="https://your-e2b-host.example.com"
E2B_DOMAIN="your-e2b-host.example.com"
E2B_SANDBOX_TIMEOUT=3600
# E2B_MAX_RETRIES=5
# E2B_RETRY_MAX_WAIT=900

# ---- GitHub 访问（必需）---------------------------------------------------
GITHUB_TOKEN="your_github_pat"

# ---- Web 搜索（evolve_agent 的 web_search 工具使用）-----------------------
SERPER_API_KEY="your_serper_api_key"

# ---- HTML 解析（evolve_agent 的 web_fetch 工具可选增强）------------------
# 三个都填才会启用；缺任一则退化为普通抓取
# BP_HTML_PARSER_URL=""
# BP_HTML_PARSER_API_KEY=""
# BP_HTML_PARSER_SECRET=""

# ---- Langfuse 可观测性（可选）---------------------------------------------
# LANGFUSE_SECRET_KEY=""
# LANGFUSE_PUBLIC_KEY=""
# LANGFUSE_HOST=""
# LANGFUSE_BASE_URL=""

# ---- 飞书通知（可选）------------------------------------------------------
# configs/base.yaml notify.feishu_webhook 通过 ${FEISHU_WEBHOOK} 引用
# FEISHU_WEBHOOK="https://open.feishu.cn/open-apis/bot/v2/hook/xxxxx"
