{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/badges/**",
              "components/battle/**",
              "components/core/**",
              "components/data/**",
              "ui_kits/arena/**",
              "ui_kits/ladder/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Chakra Petch|IBM Plex Mono|Bitter|Noto Sans SC))/i]",
        "message": "Font not provided by the design system. Available: Chakra Petch, IBM Plex Mono, Bitter, Noto Sans SC."
      },
      {
        "selector": "JSXOpeningElement[name.name='AgentCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|types|meta|gen|status|pending|rating|selected|onClick|style|key|ref|className|style|children)$/]",
        "message": "<AgentCard> doesn't accept that prop. Declared props: name, types, meta, gen, status, pending, rating, selected, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|glyph|size|shape|tone|style|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: label, glyph, size, shape, tone, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='shape'] > Literal[value!=/^(?:circle|square)$/]",
        "message": "<Avatar> shape must be one of 'circle' | 'square'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:steel|own|opp)$/]",
        "message": "<Avatar> tone must be one of 'steel' | 'own' | 'opp'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|iconLeft|iconRight|disabled|type|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, iconLeft, iconRight, disabled, type, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|headerRight|children|selected|state|padded|style|bodyStyle|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: title, headerRight, children, selected, state, padded, style, bodyStyle."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='state'] > Literal[value!=/^(?:default|selected|winner)$/]",
        "message": "<Card> state must be one of 'default' | 'selected' | 'winner'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|dot|style|key|ref|className|style|children)$/]",
        "message": "<Chip> doesn't accept that prop. Declared props: children, tone, dot, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:default|ok|live|gold|data)$/]",
        "message": "<Chip> tone must be one of 'default' | 'ok' | 'live' | 'gold' | 'data'."
      },
      {
        "selector": "JSXOpeningElement[name.name='HPBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|zh|cur|max|showValues|state|height|style|key|ref|className|style|children)$/]",
        "message": "<HPBar> doesn't accept that prop. Declared props: name, zh, cur, max, showValues, state, height, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='HPBar'] > JSXAttribute[name.name='state'] > Literal[value!=/^(?:ok|warn|low|fainted)$/]",
        "message": "<HPBar> state must be one of 'ok' | 'warn' | 'low' | 'fainted'."
      },
      {
        "selector": "JSXOpeningElement[name.name='LogLine'] > JSXAttribute > JSXIdentifier[name!=/^(?:ts|tone|label|children|style|key|ref|className|style|children)$/]",
        "message": "<LogLine> doesn't accept that prop. Declared props: ts, tone, label, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='LogLine'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:default|agent|think|decide|dmg|eff|heal|faint)$/]",
        "message": "<LogLine> tone must be one of 'default' | 'agent' | 'think' | 'decide' | 'dmg' | 'eff' | 'heal' | 'faint'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MetricStat'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|zh|value|sub|delta|tone|style|key|ref|className|style|children)$/]",
        "message": "<MetricStat> doesn't accept that prop. Declared props: label, zh, value, sub, delta, tone, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='MetricStat'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:default|elo|win|data)$/]",
        "message": "<MetricStat> tone must be one of 'default' | 'elo' | 'win' | 'data'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MoveButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|type|category|pp|ppMax|selected|onClick|style|key|ref|className|style|children)$/]",
        "message": "<MoveButton> doesn't accept that prop. Declared props: name, type, category, pp, ppMax, selected, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='MoveButton'] > JSXAttribute[name.name='category'] > Literal[value!=/^(?:Physical|Special|Status)$/]",
        "message": "<MoveButton> category must be one of 'Physical' | 'Special' | 'Status'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|zh|value|max|color|highlight|style|key|ref|className|style|children)$/]",
        "message": "<StatBar> doesn't accept that prop. Declared props: label, zh, value, max, color, highlight, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusPill'] > JSXAttribute > JSXIdentifier[name!=/^(?:status|label|style|key|ref|className|style|children)$/]",
        "message": "<StatusPill> doesn't accept that prop. Declared props: status, label, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusPill'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:PAR|BRN|PSN|TOX|SLP|FRZ|healthy|fainted)$/]",
        "message": "<StatusPill> status must be one of 'PAR' | 'BRN' | 'PSN' | 'TOX' | 'SLP' | 'FRZ' | 'healthy' | 'fainted'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TabItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|label|zh|key|ref|className|style|children)$/]",
        "message": "<TabItem> doesn't accept that prop. Declared props: id, label, zh."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tier'] > JSXAttribute > JSXIdentifier[name!=/^(?:tier|tone|style|key|ref|className|style|children)$/]",
        "message": "<Tier> doesn't accept that prop. Declared props: tier, tone, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tier'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:lime|gold)$/]",
        "message": "<Tier> tone must be one of 'lime' | 'gold'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TypeBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:type|label|color|size|style|key|ref|className|style|children)$/]",
        "message": "<TypeBadge> doesn't accept that prop. Declared props: type, label, color, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TypeBadge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<TypeBadge> size must be one of 'sm' | 'md'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
